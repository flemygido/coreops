{
  "name": "@coreops/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:eval": "vitest run src/llm/__tests__/follow-up-draft.eval.test.ts",
    "test:live-zoho": "vitest run --reporter=verbose src/connectors/__tests__/zoho-books-real.integration.test.ts",
    "test:live-whatsapp": "vitest run --reporter=verbose src/connectors/__tests__/whatsapp-real.integration.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.0.0",
    "@sinclair/typebox": "^0.34.49",
    "@supabase/supabase-js": "^2.108.2",
    "croner": "^10.0.1",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "openai": "^6.42.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "vitest": "^4.0.0"
  }
}
