# ─────────────────────────────────────────────────
# CoreOps environment variables — copy to .env
# NEVER commit .env — only commit .env.example
# ─────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Supabase
# Note: no SUPABASE_JWT_SECRET — Supabase signs access tokens with rotating
# asymmetric keys (ES256), verified locally against the project's JWKS endpoint
# via supabase-js getClaims(), not a static shared secret.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp Business Cloud API (Meta)
# Set WHATSAPP_ENABLED=true to route sends through the real Cloud API (Phase 6.5+).
# All other values are set per-business in connected_accounts.credentials_encrypted,
# EXCEPT the webhook secrets below which are global to this deployment.
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WABA_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# Template name + language used for cold follow-up sends (no open service window).
# Must be approved in Meta Business Manager before Phase 7 pilot launch.
# >>> GO-LIVE BLOCKER: leave blank until template is approved.
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE=en

# Zoho Books (Phase 6.5 — real connector behind feature flag)
# Set ZOHO_ENABLED=true to route fetches through the real Zoho Books REST API.
# All credentials are stored per-business in connected_accounts.credentials_encrypted;
# the vars below are used in integration tests and to seed the first connected_account row.
# India accounts: OAuth domain = accounts.zoho.in, API domain = www.zohoapis.in
# Get credentials: Zoho API Console → Server-based Apps → your client
ZOHO_ENABLED=false
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=
# Optional — defaults to India DC. Override for non-India accounts.
ZOHO_API_DOMAIN=https://www.zohoapis.in
ZOHO_AUTH_DOMAIN=https://accounts.zoho.in

# Tally connector (Phase 3 — leave blank until Phase 3)
# TALLY_HOST=
# TALLY_PORT=

# LLM Providers (Phase 4) — fill in whichever keys you have. Leave one blank
# to guarantee zero spend on that provider regardless of ranking order below.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Per-AI-use ranked model candidates: "provider:model,provider:model,...".
# At runtime, the code picks the FIRST candidate whose provider's API key
# above is filled in — so you control cost purely by which keys you set, no
# code change needed. List cheapest/most-affordable first for routine, high-
# volume uses; list the higher-quality provider first only once a use is
# judged "important" enough to justify the cost. See ADR-0005 Amendment.
#
# Pre-revenue default: OpenAI's cheapest tier first, Anthropic as fallback —
# bump to Sonnet/Opus-first (or add gpt-5.5) once there's revenue to justify it.
LLM_RANKING_FOLLOW_UP_DRAFT=openai:gpt-5-nano,openai:gpt-5-mini,anthropic:claude-haiku-4-5-20251001,anthropic:claude-sonnet-4-6

# Phase 5: workflow scheduling and dashboard CORS
WORKFLOW_CRON="30 1 * * *"
DASHBOARD_ORIGIN=http://localhost:3001

# Phase 6: cost controls and data retention
# Max USD per business per calendar day (UTC) before LLM drafting is blocked.
LLM_DAILY_BUDGET_USD=1.00
# Days to keep terminal follow-ups (sent/skipped/failed) before the retention purge.
RETENTION_DAYS=365

# Encryption key for credential fields (Phase 1)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Pilot onboarding (Phase 6.6 — used by scripts/setup-pilot.mts)
# Store per-pilot credentials in pilots/<name>.env, not here.
# See scripts/setup-pilot.mts --help for usage.
PILOT_EMAIL=
PILOT_BUSINESS_NAME=
OWNER_PHONE=
