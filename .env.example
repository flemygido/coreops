# ─────────────────────────────────────────────────
# CoreOps environment variables — copy to .env
# NEVER commit .env — only commit .env.example
# ─────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Supabase
# Note: no SUPABASE_JWT_SECRET — Supabase signs access tokens with rotating
# asymmetric keys (ES256), verified locally against the project's JWKS endpoint
# via supabase-js getClaims(), not a static shared secret.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp Business Cloud API (Meta)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Zoho Books (Phase 3 — leave blank until Phase 3)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=

# Tally connector (Phase 3 — leave blank until Phase 3)
# TALLY_HOST=
# TALLY_PORT=

# LLM Provider (Phase 4)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Haiku 4.5 by default — short structured drafts don't need Sonnet/Opus quality.
# See ADR-0005 for the cost/quality tradeoff.
LLM_MODEL=claude-haiku-4-5-20251001

# Encryption key for credential fields (Phase 1)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=
