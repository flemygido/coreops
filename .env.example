# ─────────────────────────────────────────────────
# CoreOps environment variables — copy to .env
# NEVER commit .env — only commit .env.example
# ─────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# WhatsApp Business Cloud API (Meta)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Zoho Books (Phase 3 — leave blank until Phase 3)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=

# Tally connector (Phase 3 — leave blank until Phase 3)
# TALLY_HOST=
# TALLY_PORT=

# LLM Provider (Phase 4 — leave blank until Phase 4)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Encryption key for credential fields (Phase 1)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=
